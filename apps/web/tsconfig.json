{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/components": ["./src/components"],
      "@/lib": ["./src/lib"],
      "@/hooks": ["./src/hooks"],
      "@forge/core": ["../../packages/core"],
      "@forge/core/*": ["../../packages/core/*"],
      "@forge/ui": ["../../packages/ui"],
      "@forge/ui/*": ["../../packages/ui/*"]
    }
  },
  "include": ["src"]
}
