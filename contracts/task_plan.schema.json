{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Forge Task Plan",
  "description": "File-level change plan produced by Architect Agent",
  "type": "object",
  "required": ["spec_id", "tasks"],
  "properties": {
    "spec_id": { "type": "string" },
    "tech_decisions": {
      "type": "object",
      "description": "Key architectural decisions made for this plan",
      "additionalProperties": { "type": "string" }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "agent", "action", "file", "description"],
        "properties": {
          "id": { "type": "string" },
          "agent": {
            "type": "string",
            "enum": ["schema", "logic", "api", "ui", "page"]
          },
          "action": {
            "type": "string",
            "enum": ["create", "modify", "delete"]
          },
          "file": { "type": "string", "description": "Relative file path" },
          "description": { "type": "string" },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Task IDs that must complete before this one"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "done", "failed"]
          }
        }
      }
    }
  }
}
